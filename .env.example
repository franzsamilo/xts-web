# Copy to .env.local and fill in values.

# PayMongo (GCash checkout links + webhooks)
# From PayMongo dashboard: Developers → API keys (test vs live secret keys).
# Webhook signing secret: Developers → Webhooks → your endpoint → signing secret.
# All three below are required for GCash to work end-to-end (create link + confirm payment).
PAYMONGO_SECRET_KEY_TEST=
PAYMONGO_SECRET_KEY=
PAYMONGO_WEBHOOK_SECRET=

# Must match the currency used for order totals (e.g. PHP).
NEXT_PUBLIC_BASE_CURRENCY=PHP

# In the PayMongo dashboard, register the webhook URL:
#   https://YOUR_DEPLOYMENT_HOST/api/payments/webhook

# NextAuth — required for sessions / Google OAuth.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bootstrap admin: the first time this email signs in via Google, the user is
# auto-promoted to the "admin" role in Firestore. Leave blank to skip bootstrap
# (admin role can also be granted manually in the users collection).
ADMIN_EMAIL=

# Shared "admin inbox" email used for product/pickup chats addressed to staff.
# This is the email a customer's chat is delivered to; admin/seller users see
# all chats addressed here in their inbox. Defaults to admin@xts.com (the
# pre-existing chat docs key on this value, so don't change it without
# migrating data).
NEXT_PUBLIC_ADMIN_EMAIL=admin@xts.com

# Firebase Admin SDK (server-side). Use a service account JSON key from
# Firebase Console → Project Settings → Service accounts. The private key must
# preserve newlines — wrap the value in quotes and keep \n escapes intact.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
